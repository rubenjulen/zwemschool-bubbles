# Caddy reverse proxy voor Zwemschool TheBubbles (Next.js).
# Plaats de inhoud in /etc/caddy/Caddyfile op de Hetzner-server en herlaad
# met:  systemctl reload caddy
#
# Next.js draait als Node-proces op poort 3000; Caddy is de HTTPS-terminator.
# Het oude domein bubbles.koniq.app verwijst permanent door naar thebubbles.

thebubbles.koniq.app {
    encode gzip zstd

    reverse_proxy localhost:3000

    # De service worker niet cachen zodat updates direct doorkomen.
    @sw path /sw.js
    header @sw Cache-Control "no-cache, no-store, must-revalidate"

    # Verberg serverversie. Overige security-headers worden door de app gezet.
    header -Server
}

# Oud domein -> permanente redirect naar het nieuwe.
bubbles.koniq.app {
    redir https://thebubbles.koniq.app{uri} permanent
}

# ---------------------------------------------------------------------------
# Zwemschool Bubbles - environment variabelen (voorbeeld).
# Kopieer naar .env.local en vul in. COMMIT NOOIT echte secrets (SEC-3).
# ---------------------------------------------------------------------------

# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Alleen server-side (Edge Functions / route handlers). NOOIT in client-code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Weer-integratie. Open-Meteo vereist geen key; basis-URL is configureerbaar
# zodat later een betaalde provider geswapt kan worden.
WEATHER_PROVIDER=open-meteo
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# E-mailprovider (MVP-kanaal). Stub tot provider gekozen is.
EMAIL_PROVIDER=stub
EMAIL_FROM=noreply@bubbles.sr

# WhatsApp Business (Fase 2). Stub tot opt-in/templates ingericht zijn.
WHATSAPP_PROVIDER=stub

# Payment provider (Fase 2). Stub; geen kaartdata in eigen app (FR-9.5/SEC-9).
PAYMENT_PROVIDER=stub
PAYMENT_WEBHOOK_SECRET=change-me

# App
NEXT_PUBLIC_APP_NAME=Zwemschool Bubbles
NEXT_PUBLIC_DEFAULT_TIMEZONE=America/Paramaribo
